    "_postman_id": "careschedule-masterdata-api",
    "name": "CareSchedule - Master Data API (Providers, Services, Mappings)",
    "description": "Complete API testing collection for CareSchedule Master Data module: Providers, Services, and ProviderService mappings. Run requests in order — POST requests auto-save IDs into environment variables for subsequent calls.",
