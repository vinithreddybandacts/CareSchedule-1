    {
      "name": "Providers",
      "item": [
        {
          "name": "1. Create Provider (POST)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.environment.set('provider_id', json.data.providerId);",
                  "    pm.test('Provider created', function () {",
                  "        pm.expect(json.success).to.be.true;",
                  "        pm.expect(json.data.name).to.eql('Dr. Anil Sharma');",
                  "        pm.expect(json.data.status).to.eql('Active');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Anil Sharma\",\n  \"specialty\": \"Cardiology\",\n  \"credentials\": \"MBBS, MD Cardiology\",\n  \"contactInfo\": \"anil.sharma@clinic.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/masterdata/providers",
              "host": ["{{base_url}}"],
              "path": ["api", "masterdata", "providers"]
            },
            "description": "Create a new provider. Auto-saves providerId to environment."
          },
          "response": []
        },
