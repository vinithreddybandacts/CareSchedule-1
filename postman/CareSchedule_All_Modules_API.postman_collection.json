{
  "info": {
    "_postman_id": "careschedule-all-modules-api",
    "name": "CareSchedule - All Modules API",
    "description": "Complete API collection covering all CareSchedule modules. Run requests in order within each folder — POST requests auto-save IDs. Working APIs return real data; skeleton APIs return 500 (NotImplementedException) until implemented.",
